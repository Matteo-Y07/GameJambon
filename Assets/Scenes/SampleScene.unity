  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
  - characterName: "Syst\xE8me"
    text: Pour vous accrocher aux murs, appuyez sur Shift.
    portrait: {fileID: 21300000, guid: cd1c2af6d3122f347b2a569bc4461239, type: 3}
  - characterName: "Syst\xE8me"
    text: Vous pouvez aussi appuyer sur Z ou S pour monter ou descendre tout en restant
      accrocher aux murs.
    portrait: {fileID: 21300000, guid: cd1c2af6d3122f347b2a569bc4461239, type: 3}
  - characterName: "Syst\xE8me"
    text: Et vous pouvez sauter depuis un mur pour effectuer un wall jump.
    portrait: {fileID: 21300000, guid: cd1c2af6d3122f347b2a569bc4461239, type: 3}
  manager: {fileID: 1531462487}
